# Google Gemini Configuration
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Tavily Search (optional — used by CardCreator for category research)
TAVILY_API_KEY=your_tavily_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# TTS Configuration
TTS_ENDPOINT_URL=http://localhost:8002/tts
TTS_TIMEOUT_SECONDS=10

# Audio output/storage
TTS_PERSIST_DIR=storage/tts
TTS_SERVE_BASE_PATH=/media/tts
TTS_RETENTION_DAYS=7
TTS_MAX_FILES=5000
